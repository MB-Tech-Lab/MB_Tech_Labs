// ─────────────────────────────────────────────────────────────
// MB Tech Labs — Prisma Schema
// ─────────────────────────────────────────────────────────────
// Uses SQLite for local development. To migrate to PostgreSQL:
//   1. Change provider below to "postgresql"
//   2. Set DATABASE_URL="postgresql://user:pass@localhost:5432/mbtl"
//   3. Run: prisma migrate dev
// No application code changes required (repository pattern abstracts this).
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth & Users
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(VIEWER)
  avatar       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  assignedProjects  Project[]      @relation("AssignedDeveloper")
  managedProjects   Project[]      @relation("ProjectManager")
  proposals         Proposal[]     @relation("ProposalAuthor")
  comments          Comment[]
  notifications     Notification[]
  activityLogs      ActivityLog[]
  meetings          Meeting[]      @relation("MeetingOrganizer")
  createdClients    Client[]       @relation("ClientCreatedBy")
  createdProjects   Project[]      @relation("ProjectCreatedBy")
  createdTasks      Task[]         @relation("TaskCreatedBy")
  assignedTasks     Task[]         @relation("TaskAssignee")
  uploadedDocuments Document[]
  // TAIMS relations
  createdPositions     InternshipPosition[] @relation("PositionCreatedBy")
  reviewedApplications Application[]        @relation("ApplicationReviewedBy")
  techReviews          TechnicalReview[]    @relation("TechReviewer")
  conductedInterviews  Interview[]          @relation("Interviewer")
  interviewFeedback    InterviewFeedback[]  @relation("FeedbackProvider")
  recruitmentNotes     RecruitmentNote[]    @relation("NoteAuthor")
  mentoredBatches      TrainingBatch[]      @relation("BatchMentor")
  mentoredTrainees     TrainingRecord[]     @relation("TraineeMentor")
  issuedCertificates   Certificate[]        @relation("CertIssuer")

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  SALES
  DEVELOPER
  VIEWER
}

// ─────────────────────────────────────────────────────────────
// Clients
// ─────────────────────────────────────────────────────────────

model Client {
  id           String   @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  phone        String?
  website      String?
  industry     String?
  address      String?
  city         String?
  country      String?
  status       String   @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  notes        String?
  createdBy    User?    @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  projects     Project[]
  submissions  SRGSubmission[]
  invoices     Invoice[]
  documents    Document[]
  meetings     Meeting[]
  comments     Comment[]
  timeline     Timeline[]

  @@map("clients")
}

// ─────────────────────────────────────────────────────────────
// Projects
// ─────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  status         String   @default("DISCOVERY") // DISCOVERY, PLANNING, UI_UX, DEVELOPMENT, TESTING, DEPLOYMENT, MAINTENANCE, ON_HOLD, CANCELLED
  priority       String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  currentStage   String   @default("Discovery")
  progress       Int      @default(0) // 0-100
  startDate      DateTime?
  endDate        DateTime?
  estimatedHours Int?
  actualHours    Int      @default(0)
  budget         Float?
  technologyStack String? // JSON array as string
  requirements   String?  // JSON object as string
  notes          String?
  client         Client   @relation(fields: [clientId], references: [id])
  clientId       String
  projectManager User?    @relation("ProjectManager", fields: [projectManagerId], references: [id])
  projectManagerId String?
  createdBy      User?    @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  assignedDevelopers User[]      @relation("AssignedDeveloper")
  submissions        SRGSubmission[]
  proposals          Proposal[]
  quotations         Quotation[]
  invoices           Invoice[]
  tasks              Task[]
  milestones         Milestone[]
  meetings           Meeting[]
  documents          Document[]
  comments           Comment[]
  timeline           Timeline[]
  stages             ProjectStage[]

  @@map("projects")
}

model ProjectStage {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  name        String
  description String?
  order       Int
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, SKIPPED
  startDate   DateTime?
  endDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_stages")
}

model Milestone {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("milestones")
}

// ─────────────────────────────────────────────────────────────
// SRG (Software Requirement Gathering)
// ─────────────────────────────────────────────────────────────

model SRGSubmission {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  templateId    String
  templateName  String
  projectType   String
  projectName   String
  status        String   @default("NEW") // NEW, REVIEWING, MEETING_SCHEDULED, APPROVED, REJECTED, ARCHIVED
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  client        Client?  @relation(fields: [clientId], references: [id])
  clientId      String?
  project       Project? @relation(fields: [projectId], references: [id])
  projectId     String?
  // Full payload as JSON string (client info, business info, goals, answers, etc.)
  payload       String   // JSON
  internalNotes String?
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  answers       SRGAnswer[]
  uploads       Document[]
  proposals     Proposal[]
  quotations    Quotation[]
  comments      Comment[]
  timeline      Timeline[]

  @@map("srg_submissions")
}

model SRGAnswer {
  id          String   @id @default(cuid())
  submission  SRGSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String
  questionId  String
  questionLabel String
  questionType String
  sectionId   String?
  sectionTitle String?
  value       String   // JSON-encoded answer
  createdAt   DateTime @default(now())

  @@map("srg_answers")
}

model QuestionTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sections    String   // JSON
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("question_templates")
}

// ─────────────────────────────────────────────────────────────
// Proposals & Quotations
// ─────────────────────────────────────────────────────────────

model Proposal {
  id          String   @id @default(cuid())
  title       String
  status      String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, ARCHIVED
  sections    String   // JSON array of {id, title, content}
  version     Int      @default(1)
  project     Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  submission  SRGSubmission? @relation(fields: [submissionId], references: [id])
  submissionId String?
  author      User?    @relation("ProposalAuthor", fields: [authorId], references: [id])
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("proposals")
}

model Quotation {
  id           String   @id @default(cuid())
  title        String
  status       String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  items        String   // JSON array of line items
  currency     String   @default("USD")
  taxRate      Float    @default(0)
  discount     Float    @default(0)
  paymentTerms String?
  validUntil   DateTime?
  notes        String?
  totalAmount  Float    @default(0)
  project      Project? @relation(fields: [projectId], references: [id])
  projectId    String?
  submission   SRGSubmission? @relation(fields: [submissionId], references: [id])
  submissionId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  invoices     Invoice[]

  @@map("quotations")
}

// ─────────────────────────────────────────────────────────────
// Invoices & Payments
// ─────────────────────────────────────────────────────────────

model Invoice {
  id           String   @id @default(cuid())
  number       String   @unique
  status       String   @default("PENDING") // PENDING, PAID, OVERDUE, CANCELLED
  amount       Float
  currency     String   @default("USD")
  taxAmount    Float    @default(0)
  totalAmount  Float
  issueDate    DateTime @default(now())
  dueDate      DateTime?
  paidDate     DateTime?
  notes        String?
  client       Client?  @relation(fields: [clientId], references: [id])
  clientId     String?
  project      Project? @relation(fields: [projectId], references: [id])
  projectId    String?
  quotation    Quotation? @relation(fields: [quotationId], references: [id])
  quotationId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  payments     Payment[]

  @@map("invoices")
}

model Payment {
  id          String   @id @default(cuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  amount      Float
  method      String?  // BANK_TRANSFER, CARD, CASH, UPI, OTHER
  reference   String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// Tasks
// ─────────────────────────────────────────────────────────────

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE, BLOCKED
  priority    String   @default("MEDIUM")
  estimatedHours Int?
  actualHours Int      @default(0)
  dueDate     DateTime?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId  String?
  createdBy   User?    @relation("TaskCreatedBy", fields: [createdById], references: [id])
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// Meetings
// ─────────────────────────────────────────────────────────────

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("VIDEO") // VIDEO, IN_PERSON, PHONE
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  startTime   DateTime
  endTime     DateTime?
  location    String?
  meetingUrl  String?
  project     Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  client      Client?  @relation(fields: [clientId], references: [id])
  clientId    String?
  organizer   User?    @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  organizerId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("meetings")
}

// ─────────────────────────────────────────────────────────────
// Notifications
// ─────────────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  type        String   // submission, proposal, quotation, invoice, team, meeting, system
  title       String
  description String
  isRead      Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?
  submissionId String?
  projectId   String?
  clientId    String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// Activity Log & Timeline
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  action      String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, STATUS_CHANGE
  entityType  String   // CLIENT, PROJECT, SRG, PROPOSAL, QUOTATION, INVOICE, TASK, MEETING
  entityId    String
  description String
  metadata    String?  // JSON
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("activity_logs")
}

model Timeline {
  id          String   @id @default(cuid())
  eventType   String
  title       String
  description String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String?
  submission  SRGSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String?
  createdAt   DateTime @default(now())

  @@map("timelines")
}

// ─────────────────────────────────────────────────────────────
// Comments & Documents
// ─────────────────────────────────────────────────────────────

model Comment {
  id          String   @id @default(cuid())
  content     String
  entityType  String   // CLIENT, PROJECT, SRG, PROPOSAL, QUOTATION
  entityId    String
  client      Client?  @relation(fields: [clientId], references: [id])
  clientId    String?
  project     Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  submission  SRGSubmission? @relation(fields: [submissionId], references: [id])
  submissionId String?
  author      User?    @relation(fields: [authorId], references: [id])
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("comments")
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String   // relative path to file
  category    String?  // LOGO, CERTIFICATES, BRAND_ASSETS, DOCUMENTS, WIREFRAMES, etc.
  entityType  String   // SRG, CLIENT, PROJECT
  entityId    String
  client      Client?  @relation(fields: [clientId], references: [id])
  clientId    String?
  project     Project? @relation(fields: [projectId], references: [id])
  projectId   String?
  submission  SRGSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String?
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt   DateTime @default(now())

  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// Reference Data
// ─────────────────────────────────────────────────────────────

model Technology {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?  // FRONTEND, BACKEND, DATABASE, CLOUD, AI, MOBILE, DEVOPS
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("technologies")
}

model Industry {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("industries")
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("services")
}

// ─────────────────────────────────────────────────────────────
// TAIMS — Talent Acquisition & Internship Management System
// ─────────────────────────────────────────────────────────────

model InternshipPosition {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  department      String   // FRONTEND, BACKEND, FULLSTACK, AI, UI_UX, QA, DEVOPS, BA
  technology      String?  // comma-separated: React,Node,PostgreSQL
  duration        String   // e.g. "3 months", "6 months"
  stipend         String?  // e.g. "₹10,000/month", "Unpaid"
  mode            String   @default("REMOTE") // REMOTE, ONSITE, HYBRID
  location        String?  // e.g. "Mumbai, India"
  openings        Int      @default(1)
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, PAUSED, ARCHIVED
  description     String
  responsibilities String? // JSON array
  skillsRequired  String?  // JSON array
  eligibility     String?  // JSON array
  techStack       String?  // JSON array
  benefits        String?  // JSON array
  learningOutcome String?
  selectionProcess String? // JSON array
  applicationDeadline DateTime?
  createdBy       User?    @relation("PositionCreatedBy", fields: [createdById], references: [id])
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  applications    Application[]

  @@map("internship_positions")
}

model Candidate {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  dateOfBirth   DateTime?
  gender        String?
  city          String?
  state         String?
  country       String?
  // Education
  college       String?
  university    String?
  degree        String?
  branch        String?
  cgpa          Float?
  currentSemester Int?
  graduationYear  Int?
  // Technical
  skills        String?  // JSON array
  // Portfolio
  portfolioWebsite String?
  githubProfile String?
  linkedinProfile String?
  resumePath    String?  // file path
  // Essay answers
  whyJoin       String?
  techInterest  String?
  bestProject   String?
  careerGoals   String?
  // Metadata
  source        String   @default("WEBSITE") // WEBSITE, LINKEDIN, REFERRAL
  status        String   @default("ACTIVE") // ACTIVE, CONVERTED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applications  Application[]
  projects      CandidateProject[]
  hackathons    CandidateHackathon[]
  certificates  Certificate[]
  technicalReviews TechnicalReview[]
  interviews    Interview[]
  notes         RecruitmentNote[]
  activities    RecruitmentActivity[]
  trainingRecords TrainingRecord[]

  @@map("candidates")
}

model Application {
  id            String   @id @default(cuid())
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String
  position      InternshipPosition @relation(fields: [positionId], references: [id])
  positionId    String
  status        String   @default("APPLIED") // APPLIED, RESUME_REVIEWED, PROJECT_REVIEWED, TECHNICAL_DISCUSSION, SELECTED, OFFER_SENT, JOINED, TRAINING, COMPLETED, REJECTED
  // Scorecard (0-100)
  scoreProgramming  Int @default(0) // /30
  scoreProjects     Int @default(0) // /25
  scoreHackathons   Int @default(0) // /15
  scoreGithub       Int @default(0) // /10
  scoreCommunication Int @default(0) // /10
  scoreAttitude     Int @default(0) // /10
  totalScore        Int @default(0)
  // Metadata
  appliedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviewedBy    User?    @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id])
  reviewedById  String?

  notes         RecruitmentNote[]
  activities    RecruitmentActivity[]
  technicalReviews TechnicalReview[]
  interviews    Interview[]
  certificates  Certificate[]
  trainingRecords TrainingRecord[]

  @@map("applications")
}

model CandidateProject {
  id            String   @id @default(cuid())
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   String
  name          String
  description   String?
  technology    String?  // comma-separated
  githubUrl     String?
  liveDemoUrl   String?
  role          String?
  achievements  String?
  screenshotPath String?
  createdAt     DateTime @default(now())

  @@map("candidate_projects")
}

model CandidateHackathon {
  id            String   @id @default(cuid())
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   String
  name          String
  year          Int?
  rank          String?
  certificatePath String?
  repositoryUrl String?
  createdAt     DateTime @default(now())

  @@map("candidate_hackathons")
}

model TechnicalReview {
  id            String   @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String
  reviewer      User?    @relation("TechReviewer", fields: [reviewerId], references: [id])
  reviewerId    String?
  // Review scores
  codingSkills     Int @default(0) // /10
  problemSolving   Int @default(0) // /10
  systemDesign     Int @default(0) // /10
  communication    Int @default(0) // /10
  learningAbility  Int @default(0) // /10
  overallRating    Int @default(0) // /50
  feedback     String?
  recommendation String? // STRONG_HIRE, HIRE, NO_HIRE
  createdAt    DateTime @default(now())

  @@map("technical_reviews")
}

model Interview {
  id            String   @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String
  type          String   @default("TECHNICAL") // TECHNICAL, HR, FINAL
  status        String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED, NO_SHOW
  scheduledAt   DateTime
  duration      Int      @default(60) // minutes
  location      String?
  meetingUrl    String?
  interviewer   User?    @relation("Interviewer", fields: [interviewerId], references: [id])
  interviewerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  feedback      InterviewFeedback[]

  @@map("interviews")
}

model InterviewFeedback {
  id            String   @id @default(cuid())
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewId   String
  providedBy    User?    @relation("FeedbackProvider", fields: [providedById], references: [id])
  providedById  String?
  rating        Int @default(0) // /10
  strengths     String?
  weaknesses    String?
  recommendation String? // STRONG_HIRE, HIRE, NO_HIRE
  notes         String?
  createdAt     DateTime @default(now())

  @@map("interview_feedback")
}

model RecruitmentNote {
  id            String   @id @default(cuid())
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String?
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   String
  content       String
  author        User?    @relation("NoteAuthor", fields: [authorId], references: [id])
  authorId      String?
  createdAt     DateTime @default(now())

  @@map("recruitment_notes")
}

model RecruitmentActivity {
  id            String   @id @default(cuid())
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String?
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   String
  action        String   // STATUS_CHANGE, NOTE_ADDED, REVIEW_COMPLETED, INTERVIEW_SCHEDULED
  description   String
  metadata      String?  // JSON
  createdAt     DateTime @default(now())

  @@map("recruitment_activities")
}

model TrainingBatch {
  id            String   @id @default(cuid())
  name          String
  startDate     DateTime
  endDate       DateTime?
  mentor        User?    @relation("BatchMentor", fields: [mentorId], references: [id])
  mentorId      String?
  status        String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt     DateTime @default(now())

  trainingRecords TrainingRecord[]
  trainingTasks   TrainingTask[]

  @@map("training_batches")
}

model TrainingTask {
  id            String   @id @default(cuid())
  batch         TrainingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  batchId       String
  title         String
  description   String?
  week          Int
  type          String   @default("LEARNING") // LEARNING, PROJECT, ASSIGNMENT, REVIEW
  status        String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt     DateTime @default(now())

  @@map("training_tasks")
}

model TrainingRecord {
  id            String   @id @default(cuid())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String
  batch         TrainingBatch? @relation(fields: [batchId], references: [id])
  batchId       String?
  mentor        User?    @relation("TraineeMentor", fields: [mentorId], references: [id])
  mentorId      String?
  status        String   @default("ORIENTATION") // ORIENTATION, TRAINING, INTERNAL_PROJECT, CLIENT_PROJECT, EVALUATION, COMPLETED
  progress      Int      @default(0) // 0-100
  startDate     DateTime @default(now())
  endDate       DateTime?
  weeklyGoals   String?  // JSON
  performance   String?  // EXCELLENT, GOOD, AVERAGE, NEEDS_IMPROVEMENT
  attendance    Int      @default(100) // percentage
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("training_records")
}

model Certificate {
  id            String   @id @default(cuid())
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String?
  type          String   // COMPLETION, PERFORMANCE, RECOMMENDATION
  title         String
  description   String?
  issuedAt      DateTime @default(now())
  issuedBy      User?    @relation("CertIssuer", fields: [issuedById], references: [id])
  issuedById    String?
  certificateNumber String @unique
  createdAt     DateTime @default(now())

  @@map("certificates")
}
